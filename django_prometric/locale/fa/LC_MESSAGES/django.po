#: providers/base.py:113 providers/base.py:116
#: templates/django_prometric/base.html:8
#: templates/django_prometric/base.html:64
msgid "Analytics"
msgstr "آمار"

#: providers/base.py:157
#, python-format
msgid "%(name)s can only look back %(days)s days; the window was shortened."
msgstr ""
"%(name)s فقط می‌تواند %(days)s روز گذشته را بررسی کند؛ پنجره زمانی کوتاه شد."

#: providers/cloudflare.py:62
msgid "Edge traffic"
msgstr "ترافیک Edge"

#: providers/cloudflare.py:90
#, python-format
msgid ""
"Set the %(token)s and %(zone)s environment variables to a Cloudflare API "
"token with Analytics Read permission and your zone ID, then restart the "
"server."
msgstr ""
"متغیرهای محیطی %(token)s و %(zone)s را با یک توکن API کلادفلر دارای دسترسی "
"Analytics Read و شناسه‌ی zone خود مقداردهی کنید و سرور را دوباره راه‌اندازی "
"کنید."

#: providers/cloudflare.py:149
msgid "Cloudflare rejected the API token. Check its permissions."
msgstr "کلادفلر توکن API را نپذیرفت. دسترسی‌های آن را بررسی کنید."

#: providers/cloudflare.py:153
#, python-format
msgid "Cloudflare API returned HTTP %(code)s."
msgstr "‏API کلادفلر پاسخ HTTP %(code)s برگرداند."

#: providers/cloudflare.py:160
#, python-format
msgid "Could not reach the Cloudflare API: %(reason)s"
msgstr "دسترسی به API کلادفلر ممکن نشد: %(reason)s"

#: providers/cloudflare.py:177
#, python-format
msgid "Cloudflare analytics error: %(message)s"
msgstr "خطای آمار کلادفلر: %(message)s"

#: providers/cloudflare.py:182
msgid "Cloudflare returned no data for this zone. Check the zone ID."
msgstr "کلادفلر داده‌ای برای این zone برنگرداند. شناسه‌ی zone را بررسی کنید."

#: providers/cloudflare.py:226
msgid ""
"Showing the last 24 hours instead of the selected range — your Cloudflare "
"plan limits path-level analytics to a 24-hour window."
msgstr ""
"به‌جای بازه‌ی انتخابی، ۲۴ ساعت اخیر نمایش داده می‌شود — پلن کلادفلر شما آمار"
" سطح مسیر را به پنجره‌ی ۲۴ ساعته محدود می‌کند."

#: providers/cloudflare.py:591
msgid "Blocked"
msgstr "مسدودشده"

#: providers/cloudflare.py:592
msgid "Challenged"
msgstr "چالش‌شده"

#: providers/cloudflare.py:593
msgid "Managed challenge"
msgstr "چالش مدیریت‌شده"

#: providers/cloudflare.py:594
msgid "JS challenge"
msgstr "چالش جاوااسکریپت"

#: providers/cloudflare.py:595
msgid "Logged"
msgstr "فقط ثبت‌شده"

#: providers/cloudflare.py:596
msgid "Skipped"
msgstr "ردشده"

#: providers/cloudflare.py:600
msgid "Managed rules"
msgstr "قواعد مدیریت‌شده"

#: providers/cloudflare.py:601
msgid "Custom rules"
msgstr "بازه‌ی دلخواه…"

#: providers/cloudflare.py:602
msgid "Firewall rules"
msgstr "قواعد فایروال"

#: providers/cloudflare.py:603
msgid "Rate limiting"
msgstr "محدودیت نرخ"

#: providers/cloudflare.py:604
msgid "Security level"
msgstr "سطح امنیتی"

#: providers/cloudflare.py:605
msgid "Bot Fight Mode"
msgstr "حالت مقابله با بات"

#: providers/cloudflare.py:606
msgid "DDoS protection"
msgstr "بخش‌ها"

#: providers/cloudflare.py:607
msgid "IP rules"
msgstr "قواعد IP"

#: providers/cloudflare.py:608
msgid "Country rules"
msgstr "کشورها"

#: providers/cloudflare.py:806
msgid "The edge cache is barely used"
msgstr "کش لبه تقریباً بی‌استفاده است"

#: providers/cloudflare.py:807
#, python-format
msgid "Only %(share)d%% of %(requests)s requests were served from cache."
msgstr "فقط %(share)d٪ از %(requests)s درخواست از کش پاسخ گرفتند."

#: providers/cloudflare.py:810
msgid ""
"Send Cache-Control headers on static files and cacheable pages so the CDN "
"can answer them without hitting Django."
msgstr ""
"روی فایل‌های استاتیک و صفحه‌های کش‌پذیر هدر Cache-Control بفرست تا CDN بدون "
"رسیدن به جنگو پاسخشان بدهد."

#: providers/cloudflare.py:819
msgid "The edge cache is pulling its weight"
msgstr "کش لبه دارد کارش را خوب انجام می‌دهد"

#: providers/cloudflare.py:820
#, python-format
msgid "%(share)d%% of requests never reached your server."
msgstr "%(share)d٪ از درخواست‌ها هرگز به سرور شما نرسیدند."

#: providers/cloudflare.py:840
msgid "Requests are failing with server errors"
msgstr "درخواست‌ها با خطای سرور شکست می‌خورند"

#: providers/cloudflare.py:841
#, python-format
msgid "%(count)s requests (%(share).1f%%) ended in a 5xx status."
msgstr "%(count)s درخواست (%(share).1f٪) به وضعیت 5xx ختم شدند."

#: providers/cloudflare.py:843
msgid "Open the application errors list and fix the top offenders."
msgstr "فهرست خطاهای برنامه را باز کن و پرتکرارترین‌ها را رفع کن."

#: providers/cloudflare.py:850
msgid "No server errors at the edge"
msgstr "هیچ خطای سروری در لبه نیست"

#: providers/cloudflare.py:851
#, python-format
msgid "None of the %(requests)s requests returned a 5xx status."
msgstr "هیچ‌کدام از %(requests)s درخواست وضعیت 5xx برنگرداندند."

#: providers/cloudflare.py:859
msgid "A lot of traffic hits dead ends"
msgstr "بخش زیادی از ترافیک به بن‌بست می‌خورد"

#: providers/cloudflare.py:860
#, python-format
msgid "%(count)s requests (%(share).1f%%) got a 404."
msgstr "%(count)s درخواست (%(share).1f٪) پاسخ 404 گرفتند."

#: providers/cloudflare.py:863
msgid ""
"Check the top routes for broken links, and add redirects for pages that "
"moved."
msgstr ""
"لینک‌های شکسته را در مسیرهای پربازدید بررسی کن و برای صفحه‌های جابه‌جاشده "
"ریدایرکت بگذار."

#: providers/cloudflare.py:876
#, python-format
msgid "%(count)s requests were blocked or challenged in this period."
msgstr "%(count)s درخواست در این بازه مسدود یا چالش شدند."

#: providers/cloudflare.py:880
#, python-format
msgid "Most-targeted path: %(path)s."
msgstr "پرحمله‌ترین مسیر: %(path)s."

#: providers/cloudflare.py:884
msgid "The firewall has your back"
msgstr "فایروال هوایت را دارد"

#: providers/cloudflare.py:890
msgid "Heavy firewall activity"
msgstr "فعالیت سنگین فایروال"

#: providers/cloudflare.py:893
msgid ""
"Review the security card; a rate limit or a stricter rule on the targeted "
"paths can cut this noise at the edge."
msgstr ""
"کارت امنیت را ببین؛ یک محدودیت نرخ یا قاعده‌ی سخت‌گیرانه‌تر روی مسیرهای هدف "
"می‌تواند این سروصدا را همان لبه قطع کند."

#: providers/cloudflare.py:909
msgid "AI crawlers take a serious slice of your traffic"
msgstr "خزنده‌های هوش مصنوعی سهم جدی‌ای از ترافیکت دارند"

#: providers/cloudflare.py:910
#, python-format
msgid "AI crawlers made %(count)s requests (%(share).1f%% of all traffic)."
msgstr ""
"خزنده‌های هوش مصنوعی %(count)s درخواست زدند (%(share).1f٪ از کل ترافیک)."

#: providers/cloudflare.py:913
msgid ""
"Decide whether that's welcome: Cloudflare can block or rate-limit AI "
"crawlers with a single setting."
msgstr ""
"تصمیم بگیر که این خوشایند هست یا نه: Cloudflare با یک تنظیم می‌تواند "
"خزنده‌های هوش مصنوعی را مسدود یا محدود کند."

#: providers/cloudflare.py:931
msgid "Most connections still speak HTTP/1.1"
msgstr "بیشتر اتصال‌ها هنوز HTTP/1.1 حرف می‌زنند"

#: providers/cloudflare.py:932
#, python-format
msgid "%(share).0f%% of requests came over HTTP/1.1."
msgstr "%(share).0f٪ از درخواست‌ها روی HTTP/1.1 آمدند."

#: providers/cloudflare.py:935
msgid ""
"That usually means bots or very old clients; real browsers negotiate HTTP/2 "
"or 3 on their own. Cross-check with the bots card."
msgstr ""
"این معمولاً یعنی ربات‌ها یا کلاینت‌های خیلی قدیمی؛ مرورگرهای واقعی خودشان "
"HTTP/2 یا 3 را برمی‌گزینند. با کارت ربات‌ها تطبیق بده."

#: providers/periods.py:18
msgid "Last 24 hours"
msgstr "۲۴ ساعت گذشته"

#: providers/periods.py:19
msgid "Last 7 days"
msgstr "۷ روز گذشته"

#: providers/periods.py:20
msgid "Last 30 days"
msgstr "۳۰ روز گذشته"

#: providers/periods.py:21
msgid "Last 3 months"
msgstr "۳ ماه گذشته"

#: providers/postgres.py:120
msgid "manual DSN"
msgstr "DSN دستی"

#: providers/postgres.py:148
msgid ""
"This source reads PostgreSQL's own statistics views. Point it at a "
"PostgreSQL database either by setting POSTGRES.DB_ALIAS to a PostgreSQL "
"connection in DATABASES, or — when that database is not PostgreSQL — by "
"giving POSTGRES.NAME/USER/PASSWORD/HOST/PORT (or POSTGRES.DSN) so the "
"provider connects directly. Query-level stats additionally need the "
"pg_stat_statements extension."
msgstr ""
"این منبع نماهای آماری خود PostgreSQL را می‌خواند. آن را به یک دیتابیس "
"PostgreSQL متصل کنید: یا POSTGRES.DB_ALIAS را به یک اتصال PostgreSQL در "
"DATABASES اشاره دهید، یا — وقتی آن دیتابیس PostgreSQL نیست — "
"POSTGRES.NAME/USER/PASSWORD/HOST/PORT (یا POSTGRES.DSN) را مشخص کنید تا "
"مستقیم متصل شود. آمار سطح کوئری علاوه بر این به افزونه‌ی pg_stat_statements "
"نیاز دارد."

#: providers/postgres.py:201
msgid ""
"A manual POSTGRES connection needs a database driver. Install one with: pip "
"install \"django-prometric[postgres]\" (psycopg2 is also accepted if you "
"already use it)."
msgstr ""
"اتصال دستی POSTGRES به درایور دیتابیس نیاز دارد. با «pip install \"django-"
"prometric[postgres]\"» نصبش کن (psycopg2 هم اگر همین حالا استفاده می‌کنی "
"پذیرفته است)."

#: providers/postgres.py:309
msgid ""
"Commit, cache-hit, deadlock and temp-file figures are lifetime counters "
"accumulated since the last statistics reset, not the selected period. They "
"are marked with a “since” badge."
msgstr ""
"ارقام کامیت، برخورد کش، بن‌بست و فایل موقت شمارنده‌هایی هستند که از آخرین "
"بازنشانی آمار انباشته شده‌اند، نه بازه‌ی انتخاب‌شده. این ارقام با نشان «از "
"تاریخ» مشخص شده‌اند."

#: providers/postgres.py:385
msgid ""
"Query statistics need the pg_stat_statements extension. Add it to "
"shared_preload_libraries, restart PostgreSQL, then run CREATE EXTENSION "
"pg_stat_statements."
msgstr ""
"آمار کوئری‌ها به افزونه‌ی pg_stat_statements نیاز دارد. آن را به "
"shared_preload_libraries اضافه کن، PostgreSQL را دوباره راه‌اندازی کن و سپس "
"CREATE EXTENSION pg_stat_statements را اجرا کن."

#: providers/postgres.py:423
msgid "Database health looks good"
msgstr "سلامت دیتابیس خوب به نظر می‌رسد"

#: providers/postgres.py:425
msgid ""
"Cache hit ratio, table bloat, index use and connection headroom are all "
"within healthy ranges."
msgstr ""
"نسبت برخورد کش، تورم جدول‌ها، استفاده از ایندکس‌ها و ظرفیت آزاد اتصال‌ها "
"همگی در محدوده‌ی سالم‌اند."

#: providers/postgres.py:440
msgid "Cache hit ratio is low"
msgstr "نسبت برخورد کش پایین است"

#: providers/postgres.py:442
#, python-format
msgid ""
"Only %(pct).1f%% of block reads were served from the cache (since the last "
"statistics reset)."
msgstr ""
"تنها %(pct).1f%% از خواندن بلوک‌ها از کش پاسخ داده شد (از آخرین بازنشانی "
"آمار)."

#: providers/postgres.py:447
msgid ""
"The working set may not fit in shared_buffers. Consider raising "
"shared_buffers or reducing the data scanned per query."
msgstr ""
"احتمالاً داده‌های پرکاربرد در shared_buffers جا نمی‌شوند. افزایش "
"shared_buffers یا کم‌کردن داده‌ی اسکن‌شده در هر کوئری را در نظر بگیر."

#: providers/postgres.py:468
msgid "Unused indexes are wasting space"
msgstr "ایندکس‌های بی‌استفاده فضا هدر می‌دهند"

#: providers/postgres.py:470
#, python-format
msgid ""
"%(count)s index(es) were never scanned since the last stats reset, holding "
"%(size)s. Largest: %(name)s on %(table)s."
msgstr ""
"%(count)s ایندکس از آخرین بازنشانی آمار هرگز اسکن نشده‌اند و %(size)s فضا "
"گرفته‌اند. بزرگ‌ترین: %(name)s روی %(table)s."

#: providers/postgres.py:480
msgid ""
"Confirm they are unused over a full workload cycle, then consider dropping "
"them to reclaim space and speed up writes."
msgstr ""
"اول در یک چرخه‌ی کاری کامل مطمئن شو استفاده نمی‌شوند، بعد برای آزادکردن فضا "
"و سریع‌ترشدن نوشتن‌ها حذفشان را در نظر بگیر."

#: providers/postgres.py:504
msgid "Some tables are bloated with dead rows"
msgstr "بعضی جدول‌ها از ردیف‌های مرده متورم شده‌اند"

#: providers/postgres.py:506
#, python-format
msgid ""
"%(name)s is %(pct).0f%% dead tuples and has not been autovacuumed recently."
msgstr "%(pct).0f%% از %(name)s ردیف مرده است و اخیراً autovacuum نشده."

#: providers/postgres.py:510
msgid ""
"Run VACUUM (ANALYZE) on it, and tune autovacuum thresholds if it bloats "
"again."
msgstr ""
"رویش VACUUM (ANALYZE) اجرا کن و اگر دوباره متورم شد آستانه‌های autovacuum را"
" تنظیم کن."

#: providers/postgres.py:527 providers/sentry.py:393
msgid "Some database queries are slow"
msgstr "بعضی کوئری‌های دیتابیس کندند"

#: providers/postgres.py:528 providers/sentry.py:394
#, python-format
msgid "The worst averages %(avg)dms over %(calls)s calls: %(query)s"
msgstr ""
"بدترینشان به‌طور میانگین %(avg)d میلی‌ثانیه در %(calls)s فراخوانی: %(query)s"

#: providers/postgres.py:535
msgid ""
"Add an index for its filter columns or rework the query — the full list is "
"in the slowest-queries card."
msgstr ""
"برای ستون‌های فیلترش ایندکس اضافه کن یا کوئری را بازنویسی کن — فهرست کامل در"
" کارت کندترین کوئری‌هاست."

#: providers/postgres.py:550
msgid "Connection slots are nearly exhausted"
msgstr "ظرفیت اتصال‌ها تقریباً پر شده است"

#: providers/postgres.py:551
#, python-format
msgid "%(used)s of %(max)s connections are in use (%(pct).0f%%)."
msgstr "%(used)s از %(max)s اتصال در حال استفاده است (%(pct).0f%%)."

#: providers/postgres.py:554
msgid ""
"Add a connection pooler such as PgBouncer, or lower the application's pool "
"size, before new connections are refused."
msgstr ""
